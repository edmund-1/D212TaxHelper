  <xs:element name="d212">
    <xs:annotation>
      <xs:documentation>Radacina declaratiei</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence>
        <!-- Capitolul I Date privind veniturile realizate -->
        <xs:element minOccurs="0" name="oblig_realizat">
          <xs:annotation>
            <xs:documentation>Date privind veniturile realizate, declarate in Capitolul I.(BG-01000)</xs:documentation>
          </xs:annotation>
          <!-- Capitolul I, Sectiunea 1,  Subsectiunea 3: Date privind impozitul pe veniturile din inchirierrea in scop turistic a camerelor situate in locuinte proprietate personale -->
          <xs:complexType>
            <xs:attribute name="real_camere_inchiriere" type="N3Type" use="optional">
              <xs:annotation>
                <xs:documentation>Numar camere(BT-01001)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_venit_inchiriere" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit anual(BT-01002)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_impozit_inchiriere" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Impozit anual (rd.1 *10%)(BT-01003)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- Capitolul I, Sectiunea 2,  Subsectiunea 2: Date privind contributia de asigurari sociale si contributia de asigurari social ede sanatate datorate pentru venituri asimilate salariilor pentru activitatea desfasurata in strainatate -->
            <xs:attribute name="str_cas_baza" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Baza anuala de calcul al CAS(BT-01004)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="str_cas_datorat" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CAS datorata (rd.1 x 25%)(BT-01005)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="str_cass_baza" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Baza anuala de calcul al CASS(BT-01006)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="str_cass_datorat" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata (rd.3 x 10%)(BT-01007)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- Capitolul I, Sectiunea 3,  Subsectiunea 1: Date privind contributia de asigurari sociale datorata -->
            <xs:attribute name="bifa_cas_real" type="N1Type" use="optional">
              <xs:annotation>
                <xs:documentation>Bifa optiune venituri realizate(BT-01008)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="bifa_cas_recalculat" type="N1Type" use="optional">
              <xs:annotation>
                <xs:documentation>Am realizat venituri peste plafon minim recalculat(BT-01009)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="bifa_cas_sub_plafon" type="N1Type" use="optional">
              <xs:annotation>
                <xs:documentation>Am realizat venituri sub plafon minim si optez pentru plata CAS(BT-01010)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cas_total_ven" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Total venituri anuale realizate din activitati independente si drepturi de proprietate intelectuala  potrivit art.148 alin.(2) din Codul fiscal(BT-01011)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cas_baza" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Baza anuala calcul a CAS (Venit ales pentru plata CAS)(BT-01012)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cas_datorat" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CAS datorata (rd.2 x 25%)(BT-01013)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cas_retinut_platitor" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CAS retinuta de platitorul de venit conform art.151 alin. (6^1) din Codul fiscal(BT-01014)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cas_dif_plus" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Diferenta stabilita in plus (rd.3 - rd.4)(BT-01015)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- Capitolul I, Sectiunea 3,  Subsectiunea 2 Date privind contributia de asigurari sociale de sanatate datorata -->
            <xs:attribute name="bifa_cass_datorat_ai" type="N1Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata pentru veniturile din activitati independente prevazute la art.155 alin.(1) lit.b) din Codul fiscal(BT-01016)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="bifa_cass_datorat_dpi" type="N1Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata pentru veniturile din drepturi de proprietate intelectuala  asocierea cu o persoana juridica  contribuabil potrivit titlului II sau titlului III din Codul fiscal,  cedarea folosintei bunurilor,  activitati agricole, silvicultura si piscicultura,  venituri din investitii si/sau din alte surse prevazute la art. 155 alin. (1) lit. c) - h) din Codul fiscal(BT-01017)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- 2.1 Date privind contributia de asigurari sociale datorata CASS datorata pentru veniturile din activitati independente prevazute la art.155 alin.(1) lit.b) din Codul fiscal -->
            <xs:attribute name="cass_total_ven_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Total venituri anuale realizate din activitati independente si drepturi de proprietate intelectuala  potrivit art.148 alin.(2) din Codul fiscal (BT-01018)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="baza_cass_datorat_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Baza anuala de calcul al CASS(BT-01019)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_anuala_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS anuala (rd.2 x 10%)(BT-01020)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_datorat_art180_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata ca urmare a exercitarii optiunii potrivit art.180 alin.(2) din Codul Fiscal(BT-01021)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_datorat_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata(rd.3 - rd.4 sau rd.4, dupa caz)(BT-01022)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_retinut_platitor_alin6_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS retinuta de platitorul de venit conform art.174 alin. (10) din Codul fiscal(BT-01023)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_dif_plus_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Diferenta stabilita in plus (rd.5 – rd.6)(BT-01024)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_dif_minus6_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Diferenta stabilita in minus (rd.6 - rd.5)(BT-01025)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_retinut_platitor_alin7_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>9. CASS retinuta de platitorii de venituri conform art.174 alin.(11) din Codul fiscal</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_dif_minus8_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>10. Diferenta stabilita în minus (suma de la rd.9 -10% x 60 salarii minime brute pe tara )</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- 2.2. CASS datorata pentru veniturile din drepturi de proprietate intelectuala, asocierea cu o persoana juridica, contribuabil potrivit titlului II sau titlului III din Codul fiscal, cedarea folosinţei bunurilor, activitaţi agricole, silvicultura şi piscicultura, venituri din investiţii și/sau din alte surse prevazute la art. 155 alin. (1) lit. c) - h) din Codul fiscal -->
            <xs:attribute name="bifa_cass_real" type="N1Type" use="optional">
              <xs:annotation>
                <xs:documentation>Bifa optiune venituri realizate(BT-01026)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_ven_dpi" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit din drepturi de proprietate intelectuala(BT-01027)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_ven_asc" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit distribuit din asocieri cu persoane juridice  contribuabili potrivit prevederilor titlului II sau titlului III din Codul fiscal(BT-01028)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_ven_cfb" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit din cedarea folosintei bunurilor(BT-01029)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_ven_inv" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit si/sau cistig din investisii(BT-01030)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_ven_asp" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit din activitati agricole  silvicultura si piscicultura(BT-01031)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_ven_alt" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit din alte surse(BT-01032)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_total_ven" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>TOTAL(BT-01033)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_baza" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Baza anuala de calcul a CASS(numar luni x salariu minim)(BT-01034)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_anuala" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata (rd.2 x 10%)(BT-01035)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_datorat_art180" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata ca urmare a exercitarii optiunii potrivit art.180 alin.(2) din Codul Fiscal(BT-01036)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_datorat" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS datorata (rd.2 x 10%)(BT-01037)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_retinut" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS resinuta de platitorul de venit conform art.174^1 alin. (8) din Codul fiscal(BT-01038)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_dif_plus" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Diferenta stabilita in plus (rd.5 i rd.6)(BT-01039)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="cass_dif_minus" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Diferenta stabilita in minus(rd.6 i rd.5)(BT-01040)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- Capitolul I, Sectiunea 4 Stabilirea impozitului anual datorat pe venitul net anual impozabil realizat din activitati independente, impuse în sistem real -->
            <xs:attribute name="real_venit_net_recalculat_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Suma veniturilor nete recalculate din activitati independente  impuse in sistem real (rd.7 de la 1.1.B)(BT-01041)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_cas-deduc_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CAS deductibila(rd.5 de la subsecsiunea 4.1)(BT-01042)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_cass-deductibil_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CASS deductibila (rd.6 de la subsecsiunea 4.2)(BT-01043)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_venit_net_impozabil_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit net anual impozabil (rd.1-rd.2 - rd.3 )(BT-01044)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_venit_net_impozabil_redus_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Venit net anual impozabil redus(BT-01045)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_impozit_datorat_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Total impozit anual datorat (rd.4x10% sau rd.5x10%)(BT-01046)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- Capitolul I, Sectiunea 4, Subsectiunea 4.1 Stabilirea contributiei de asigurari sociale deductibile pentru calculul impozitului pe venit, potrivit art.118 din Codul fiscal -->
            <xs:attribute name="real_cas_venit_net_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Suma veniturilor nete anuale din activitati independente impuse in sistem real (rd.3 de la 1.1.B)(BT-01047)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_cas_total_ven_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>Total venituri anuale realizate din activitati independente si drepturi de proprietate intelectuala  potrivit art.148 alin.(2) din Codul fiscal (rd.1 de la 3.1)(BT-01048)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_cas_pondere_ai" use="optional">
              <xs:annotation>
                <xs:documentation>
                  Ponderea venitului net anual determinat în sistem real în total venituri cumulate
                  potrivit art.148 alin.(2) din Codul fiscal (rd.1/rd.2)(BT-01049)
                </xs:documentation>
              </xs:annotation>
              <xs:simpleType>
                <xs:restriction base="xs:decimal">
                  <xs:minExclusive value="0"/>
                  <xs:maxInclusive value="1"/>
                  <xs:totalDigits value="6"/>
                  <xs:fractionDigits value="5"/>
                </xs:restriction>
              </xs:simpleType>
            </xs:attribute>
            <xs:attribute name="real_cas_datorata_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>CAS datorata (rd.3 de la subsecsiunea 1  secsiunea 3)(BT-01050)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="real_cas_deductibila_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>5. CAS deductibila (rd.3 x rd.4)(BT-01051)</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <!-- Capitolul I, Sectiunea 4, Subsectiunea 4.2 Stabilirea contributiei de asigurari sociale de sanatate deductibile pentru calculul impozitului pe venit, potrivit art.118 din Codul fiscal -->
            <xs:attribute name="real_cass_venit_net_ai" type="N15Type" use="optional">
              <xs:annotation>
                <xs:documentation>1.Suma veniturilor nete anuale din activitati independente impuse in sistem real (rd.3 de la 1.1.B)(BT-01052)</xs:documentation>
